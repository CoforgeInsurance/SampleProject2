<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
           xmlns:camel="http://camel.apache.org/schema/blueprint"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
           xmlns:cxf="http://camel.apache.org/schema/blueprint/cxf"
           xmlns:jaxws="http://cxf.apache.org/blueprint/jaxws"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://cxf.apache.org/transports/camel http://cxf.apache.org/transports/camel.xsd        https://www.osgi.org/xmlns/blueprint/v1.0.0 http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd        http://camel.apache.org/schema/blueprint/cxf http://camel.apache.org/schema/blueprint/cxf/camel-cxf.xsd        http://camel.apache.org/schema/blueprint http://camel.apache.org/schema/blueprint/camel-blueprint.xsd">
    <reference availability="mandatory"
               filter="(osgi.jndi.service.name=service/oracleds)"
               id="oracle-db" interface="javax.sql.DataSource"/>
    <bean class="org.apache.camel.component.sql.SqlComponent" id="oracle">
        <property name="dataSource" ref="oracle-db"/>
    </bean>
    <reference availability="mandatory"
               filter="(propertiesConfig.name=propertiesLoader)"
               id="properties-conf" interface="com.aviva.ca.esb.core.conf.client.api.PropertiesLoaderService"/>
    <bean
            class="com.ca.aviva.esb.api.notification.util.PropertiesLoader" id="propertiesLoader">
        <property name="propertiesLoaderService" ref="properties-conf"/>
    </bean>
    <bean
            class="com.aviva.ca.esb.core.conf.logging.LoggingSentEventNotifier" id="loggingSentEventNotifier"/>
    <bean
            class="com.aviva.ca.esb.core.conf.logging.transactionlog.TransactionLogging" id="genericTransactionLogging"/>
    <bean class="org.apache.cxf.ws.security.wss4j.WSS4JInInterceptor" id="WSSECAuthenticate">
        <property name="properties">
            <map>
                <entry key="action" value="UsernameToken"/>
                <entry key="passwordType" value="PasswordText"/>
            </map>
        </property>
    </bean>
    <bean
            class="org.apache.cxf.interceptor.security.JAASLoginInterceptor" id="authenticationInterceptor">
        <!-- Name of the JAAS Context -->
        <property name="contextName" value="ldapAvivaCanada"/>
        <property name="roleClassifier" value="RolePrincipal"/>
        <property name="roleClassifierType" value="classname"/>
    </bean>
    <bean
            class="org.apache.cxf.interceptor.security.SimpleAuthorizingInterceptor" id="authorizationInterceptor">
        <property name="methodRolesMap">
            <map>
                <entry key="notification" value="eFuseEsbSvcAccess"/>
                <entry key="statusCallBack" value="eFuseEsbSvcAccess"/>
            </map>
        </property>
    </bean>
    <bean class="com.aviva.ca.esb.core.conf.cxf.features.InboundFeature" id="inBoundFeature">
        <argument index="0" ref="oracle"/>
        <argument index="1" value="${DB_LOGGING}"/>
    </bean>
    <bean
            class="com.aviva.ca.esb.core.conf.logging.transactionlog.TransactionLogging" id="transactionLogging"/>
    <bean
            class="com.aviva.ca.esb.core.conf.logging.transactionlog.TransactionLog"
            id="transactionLog" init-method="init">
        <argument type="java.util.List">
            <list>
                <value>com.avivacanada.services.fuse.notification.v1.SendPhoneNotificationResponse</value>
                <value>com.avivacanada.services.fuse.notification.v1.SendPhoneNotificationRequest</value>
            </list>
        </argument>
        <argument type="java.util.List">
            <list>
                <value>com.avivacanada.services.fuse.notification.v1.Notification</value>
                <value>com.avivacanada.services.fuse.notificationcallback.v1.service.Notification</value>
            </list>
        </argument>
    </bean>
    <!-- Following are required for the NotificationStatus -->
    <bean class="org.apache.cxf.jaxrs.security.JAASAuthenticationFilter" id="authenticationFilter">
        <property name="contextName" value="ldapAvivaCanada"/>
    </bean>
    <!-- Following are required for the Fuse Notification -->
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationFuseRqMapper" id="phoneNotificationFuseRqMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationFuseRqLogging" id="phoneNotificationFuseRqLogging"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationFuseRqValidator" id="phoneNotificationFuseRqValidator"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationFuseRsMapper" id="phoneNotificationFuseRsMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationFuseRsErrorMapper" id="phoneNotificationFuseRsErrorMapper"/>
    <!-- Following are required for the Node Notification -->
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationNodeRqInput" id="phoneNotificationNodeRqInput"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationNodeRqLogging" id="phoneNotificationNodeRqLogging"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationNodeInvoker" id="phoneNotificationNodeInvoker"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationNodeRsMapper" id="phoneNotificationNodeRsMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.PhoneNotificationNodeRsErrorMapper" id="phoneNotificationNodeRsErrorMapper"/>
    <bean
            class="com.avivacanada.cc.ws.com.avivacanada.integration.webservice.digitalnotification.digitalnotificationserviceapi.ClaimCenterNotificationServiceInvoker" id="claimcenterNotificationInvoker">
        <property name="digitalNotificationService" ref="CCDigitalNotificationProxy"/>
    </bean>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRqLogging" id="notificationStatusupdateRqLogging"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRqMapper" id="notificationStatusupdateRqMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRqValidator" id="notificationStatusupdateRqValidator"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRsMapper" id="notificationStatusupdateRsMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRsErrorMapper" id="notificationStatusupdateRsErrorMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationStatusUpdateRsErrorQueue" id="notificationStatusupdateRsErrorQueue"/>
    <!-- Following are required for the Node Unsubscribe -->
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRqLogging" id="notificationUnsubscribeRqLogging"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRqMapper" id="notificationUnsubscribeRqMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRqValidator" id="notificationUnsubscribeRqValidator"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRsMapper" id="notificationUnsubscribeRsMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRsErrorMapper" id="notificationUnsubscribeRsErrorMapper"/>
    <bean
            class="com.ca.aviva.esb.api.notification.notificationcallback.processor.NotificationUnsubscribeRsErrorQueue" id="notificationUnsubscribeRsErrorQueue"/>
    <bean
            class="org.apache.camel.routepolicy.quartz2.CronScheduledRoutePolicy" id="batchSchedulePolicy">
        <property name="routeStartTime" value="{{COP_BATCH_SCHEDULE_START_TIME}}"/>
        <property name="routeStopTime" value="{{COP_BATCH_SCHEDULE_STOP_TIME}}"/>
    </bean>
    <bean
            class="org.apache.camel.routepolicy.quartz2.CronScheduledRoutePolicy" id="retrySchedulePolicy">
        <property name="routeStartTime" value="{{COP_RETRY_SCHEDULE_START_TIME}}"/>
        <property name="routeStopTime" value="{{COP_RETRY_SCHEDULE_STOP_TIME}}"/>
    </bean>
    <bean id="nodeRequestObjectMapper" class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.NodeRequestObjectMapper"/>
    <bean id="nodeRequestRetriableChecker" class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.NodeRequestRetriableChecker"/>
    <bean id="mapNotificationStatusUpdateRequest" class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.MapNotificationStatusUpdateRequest"/>
    <bean id="authorizationHeaderEncoderProcessor" class="com.ca.aviva.esb.api.notification.sendphonenotification.processor.AuthorizationHeaderEncoderProcessor"/>

    <bean id="notification" class="com.avivacanada.services.fuse.notificationcallback.v1.service.Notification"/>
</blueprint>

