<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
	xmlns:camel="http://camel.apache.org/schema/blueprint"
	xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
	xmlns:cxf="http://camel.apache.org/schema/blueprint/cxf" xmlns:jaxws="http://cxf.apache.org/blueprint/jaxws"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://cxf.apache.org/transports/camel http://cxf.apache.org/transports/camel.xsd        https://www.osgi.org/xmlns/blueprint/v1.0.0 http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd        http://camel.apache.org/schema/blueprint/cxf http://camel.apache.org/schema/blueprint/cxf/camel-cxf.xsd        http://camel.apache.org/schema/blueprint http://camel.apache.org/schema/blueprint/camel-blueprint.xsd">
	<routeContext id="notificationContext-node"
		xmlns="http://camel.apache.org/schema/blueprint">
		<route id="sendNodePhoneNotification" streamCache="true">
			<from uri="activemqcompcop:{{COP_CLAIMNOTIFICATION_REAL_QUEUE}}" />
			<log message="lognotify: send phone notification transaction starts" />
			<doTry>
				<setProperty propertyName="loadProperties">
					<simple>${ref:propertiesLoader}</simple>
				</setProperty>
				<log message="lognotify: Before phoneNotificationNodeRqInput" />
				<setProperty propertyName="copClaimsNotificationPwd">
					<simple>${bean:copClaimsNotificationPwd.toString}</simple>
				</setProperty>
				<process ref="phoneNotificationNodeRqInput" />
				<setProperty propertyName="SERVICE">
					<simple resultType="java.lang.String">SendPhoneNotificationNodeService</simple>
				</setProperty>
				<setProperty propertyName="APPLICATION_ID">
					<simple>NODE</simple>
				</setProperty>
				
				<log message="lognotify: Before phoneNotificationNodeRqLogging" />
				<process ref="phoneNotificationNodeRqLogging" />
				<log message="lognotify: to sendPhoneNotificationNodeClientCall" />
				<to pattern="InOut" uri="bean:phoneNotificationNodeInvoker" />
				<choice>
					<when>
						<simple>${in.header.CamelHttpResponseCode} == '400'</simple>
						<setHeader headerName="ORIGINALEXCEPTION">
							<simple>${body}</simple>
						</setHeader>
						<setHeader headerName="logOperation">
							<simple>insertOutboundOriginalErr</simple>
						</setHeader>
						<to uri="direct-vm:transactionloggingGateway" />
						<log message="lognotify: End of logging the outbound error" />
						<!--When node returns http error code 400 (Bad data / Client caused 
							error ), ESB needs to inform this failure to Claims center -->
						<log message="Informing CC about wrong phone number" />
						<to uri="direct:notifyNodeFailureToClaimsCenter" />
					</when>
					<otherwise>
						<process ref="phoneNotificationNodeRsMapper" />
						<setHeader headerName="logOperation">
							<simple>insertOutbound</simple>
						</setHeader>
						<log
							message="lognotify: To log the outbound request message to notification center" />
						<to uri="direct-vm:transactionloggingGateway" />
						<log
							message="lognotify: The outbound request message to notification center has been logged" />
					</otherwise>
				</choice>
				<doCatch>
					<exception>java.lang.Exception</exception>
					<handled>
						<constant>true</constant>
					</handled>
					<to uri="direct:sendPhoneNotificationNodeErrorResponse" />
				</doCatch>
			</doTry>
		</route>
		<route id="direct:sendPhoneNotificationNodeResponseErrorRoute">
			<from uri="direct:sendPhoneNotificationNodeErrorResponse" />
			<log message="lognotify: To check if error handler is required" />
			<process ref="phoneNotificationNodeRsErrorMapper" />
			<log message="lognotify: To log the outbound error" />
			<setHeader headerName="logOperation">
				<simple>insertOutboundOriginalErr</simple>
			</setHeader>
			<to uri="direct-vm:transactionloggingGateway" />
			<log message="lognotify: End of logging the outbound error" />
			<log
				message="lognotify: Inside error handler with left retry times ${header.COP_CLAIMNOTIFICATION_RETRIES}" />
			<choice>
				<when>
					<simple>${header.RETRIABLE} == 'false'</simple>
					<log message="lognotify: To update CC Phone Notification Error" />
					<to pattern="InOnly"
						uri="activemqcompcop:{{COP_CLAIMNOTIFICATION_ERROR_QUEUE}}" />
				</when>
				<when>
					<simple>${header.RETRIABLE} == 'true' and ${header.RETRYEXPIRED} == 'true'</simple>
					<log message="lognotify: To update CC Phone Notification Error" />
					<to pattern="InOnly"
						uri="activemqcompcop:{{COP_CLAIMNOTIFICATION_RETRY_QUEUE}}" />
				</when>
				<otherwise>
					<log
						message="lognotify: message is to put into {COP_CLAIMNOTIFICATION_REAL_QUEUE} queue after sleep " />
					<to pattern="InOnly"
						uri="activemqcompcop:{{COP_CLAIMNOTIFICATION_REAL_QUEUE}}" />
				</otherwise>
			</choice>
		</route>
		<route>
			<from uri="direct-vm:transactionloggingGateway" />
			<setProperty propertyName="SERVICENAMEBKP">
				<simple>${property.SERVICE}</simple>
			</setProperty>
			<setHeader headerName="SERVICENAMEBKP">
				<simple>${headers.SERVICE}</simple>
			</setHeader>
			<setProperty propertyName="SERVICE">
				<simple resultType="java.lang.String">NotificationService</simple>
			</setProperty>
			<setHeader headerName="SERVICE">
				<simple resultType="java.lang.String">NotificationService</simple>
			</setHeader>
			<to uri="direct-vm:transactionlogging" />
			<log
				message="TXN LOGGED : ${body} | Correlation : ${headers.REQUEST_CORRELATION_ID}" />
			<setProperty propertyName="SERVICE">
				<simple>${property.SERVICENAMEBKP}</simple>
			</setProperty>
			<setHeader headerName="SERVICE">
				<simple>${headers.SERVICENAMEBKP}</simple>
			</setHeader>
		</route>
		<route streamCache="true">
			<!--Calls routines to notify CC about http 400 -->
			<from uri="direct:notifyNodeFailureToClaimsCenter" />
			<log message="Informing Claims center" />
			<!--<to uri="log:RESPONSEOBJECT?showAll=true"/> -->
			<doTry>
				<unmarshal ref="nodeResponseFormat" />
				<doCatch>
					<exception>java.lang.Exception</exception>
					<handled>
						<constant>true</constant>
					</handled>
					<log
						message="Found Twilio error code. Parsing json to retrieve errorCode and errorDescription" />
					<setProperty propertyName="isTwilioError">
						<constant>true</constant>
					</setProperty>
					<doTry>
						<setProperty propertyName="errorCode">
							<jsonpath resultType="java.lang.String">$.errorCode</jsonpath>
						</setProperty>
						<setProperty propertyName="errorMessage">
							<jsonpath resultType="java.lang.String">$.message</jsonpath>
						</setProperty>
						<doCatch>
							<exception>org.apache.camel.ExpressionEvaluationException</exception>
							<setHeader headerName="ORIGINALEXCEPTION">
								<simple resultType="java.lang.String">${property.CamelExceptionCaught}</simple>
							</setHeader>
							<!--<to uri="log:ERRORAUDIT?showAll=true"/> <inOnly uri="direct:sendPhoneNotificationNodeErrorResponse"/> -->
						</doCatch>
					</doTry>
					<log
						message="Twilio errorCode = ${property.errorCode} / message = ${property.errorMessage}" />
				</doCatch>
			</doTry>
			<process ref="mapNotificationStatusUpdateRequest" />
			<log message="Final request to CC : ${body}" />
			<to uri="direct:notificationstatusupdateOutbound" />
		</route>
	</routeContext>
</blueprint>
