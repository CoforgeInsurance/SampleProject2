<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
    xmlns:camel="http://camel.apache.org/schema/blueprint"
    xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
    xmlns:cxf="http://camel.apache.org/schema/blueprint/cxf"
    xmlns:enc="http://karaf.apache.org/xmlns/jasypt/v1.0.0"
    xmlns:ext="http://aries.apache.org/blueprint/xmlns/blueprint-ext/v1.0.0"
    xmlns:http="http://cxf.apache.org/transports/http/configuration"
    xmlns:jaxws="http://cxf.apache.org/blueprint/jaxws"
    xmlns:sec="http://cxf.apache.org/configuration/security"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://cxf.apache.org/transports/camel http://cxf.apache.org/transports/camel.xsd        https://www.osgi.org/xmlns/blueprint/v1.0.0 http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd        http://camel.apache.org/schema/blueprint/cxf http://camel.apache.org/schema/blueprint/cxf/camel-cxf.xsd        http://camel.apache.org/schema/blueprint http://camel.apache.org/schema/blueprint/camel-blueprint.xsd">
    <!-- <ext:property-placeholder
        id="property-placeholder-4f5c937b-05e6-44d8-b6f4-4b4047e28ed4"
        placeholder-prefix="$(" placeholder-suffix=")">
        <ext:location>classpath:properties/application_path.properties
		</ext:location>
    </ext:property-placeholder>
    <ext:property-placeholder
        id="property-placeholder-95d821d3-7005-47e1-9793-079f5e5fb676"
        placeholder-prefix="{{" placeholder-suffix="}}">
        <ext:location>file:$(application.properties.filepath)</ext:location>
    </ext:property-placeholder> -->
    <cm:property-placeholder
        id="property-placeholder-43d8249f-f960-454c-8860-df868e252601"
        persistent-id="org.apache.cxf.osgi" placeholder-prefix="$("
        placeholder-suffix=")" update-strategy="reload">
        <cm:default-properties>
            <cm:property name="application.properties.filepath" value="application.properties.filepath"/>
        </cm:default-properties>
    </cm:property-placeholder>
    <ext:property-placeholder
        id="property-placeholder-ca7d1865-139d-4d2f-90ed-bdf2526e45fa"
        placeholder-prefix="{{" placeholder-suffix="}}">
        <ext:location>file:$(application.properties.filepath)</ext:location>
    </ext:property-placeholder>
    <enc:property-placeholder
        id="property-placeholder-3215c686-fcbe-4c37-a540-5afe82f199f1"
        placeholder-prefix="ENC(" placeholder-suffix=")">
        <enc:encryptor class="org.jasypt.encryption.pbe.StandardPBEStringEncryptor">
            <property name="config">
                <bean class="org.jasypt.encryption.pbe.config.EnvironmentStringPBEConfig">
                    <property name="algorithm">
                        <bean
                            class="com.aviva.ca.vault.service.VaultService" factory-method="getKeyValue">
                            <argument value="Algorithm"/>
                        </bean>
                    </property>
                    <property name="password">
                        <bean
                            class="com.aviva.ca.vault.service.VaultService" factory-method="getKeyValue">
                            <argument value="MasterKey"/>
                        </bean>
                    </property>
                </bean>
            </property>
        </enc:encryptor>
    </enc:property-placeholder>
    <http:conduit id="conduit-95ee9c8a-cad6-4870-ac6b-ecff0df41009" name=".*">
        <http:tlsClientParameters disableCNCheck="true">
            <sec:keyManagers keyPassword="{{KEYSTORE_PASSWORD}}">
                <sec:keyStore file="{{KEYSTORE_RESOURCE}}"
                    password="{{KEYSTORE_PASSWORD}}" type="JKS"/>
            </sec:keyManagers>
            <sec:trustManagers>
                <sec:keyStore file="{{TRUSTSTORE_RESOURCE}}"
                    password="{{TRUSTSTORE_PASSWORD}}" type="JKS"/>
            </sec:trustManagers>
        </http:tlsClientParameters>
        <http:client AutoRedirect="true" Connection="Keep-Alive"/>
    </http:conduit>
    <bean class="java.lang.String" id="copClaimsNotificationPwd">
        <argument value="{{COP_CLAIMNOTIFICATION_PASSWORD}}"/>
    </bean>
    <bean class="java.lang.String" id="ccCreateClaimPwd">
        <argument value="{{CC_CREATECLAIM_PASSWORD}}"/>
    </bean>
    <camelContext id="camelContext-notification" xmlns="http://camel.apache.org/schema/blueprint">
        <routeContextRef ref="notificationContext-fuse"/>
        <routeContextRef ref="notificationContext-node"/>
        <routeContextRef ref="notificationcallback_statusupdate"/>
        <routeContextRef ref="notificationcallback_unsubscribe"/>
        <dataFormats>
            <json id="nodeRequestFormat" library="Jackson" unmarshalTypeName="com.avivacanada.avivaapi.claims.v1.twilio.sms.NotificationRequestType"/>
            <json id="nodeResponseFormat" library="Jackson" unmarshalTypeName="com.avivacanada.avivaapi.claims.v1.twilio.sms.NotificationResponseType"/>
        </dataFormats>
        <route id="notificationService">
            <from id="_notificationRequest" uri="cxf:bean:notificationServiceSoapEndpoint?loggingFeatureEnabled=true"/>
            <log id="_serviceReceived" message="lognotify: Notification Service call received, camel transaction starts"/>
            <setProperty id="_setPropertyNotificationRequest" propertyName="loadProperties">
                <simple>${ref:propertiesLoader}</simple>
            </setProperty>
            <recipientList id="_routeToOperation">
                <simple>direct:${header.operationName}</simple>
            </recipientList>
        </route>
        <route id="cxfrs_notificationcallbackService">
            <from id="_receiveService" uri="cxfrs:bean:notificationCallBackRestEndpoint?bindingStyle=SimpleConsumer"/>
            <setProperty id="_setPropertyNotificationCallback" propertyName="loadProperties">
                <simple>${ref:propertiesLoader}</simple>
            </setProperty>
            <choice id="_choiceCallback">
                <when id="_whenStatusUpdate">
                    <simple>${header.CamelHttpPath} == '/statusupdate'</simple>
                    <setHeader headerName="operationName" id="_setHeader1">
                        <constant>statusupdate</constant>
                    </setHeader>
                </when>
                <when id="_whenUnsubscribe">
                    <simple>${header.CamelHttpPath} == '/unsubscribe'</simple>
                    <setHeader headerName="operationName" id="_setHeader2">
                        <constant>unsubscribe</constant>
                    </setHeader>
                </when>
            </choice>
            <log id="_logOperation" message="lognotify: the message is routed to ${header.operationName} "/>
            <recipientList id="_routeToCallbackService">
                <simple>direct:${header.operationName}</simple>
            </recipientList>
        </route>
    </camelContext>
</blueprint>
