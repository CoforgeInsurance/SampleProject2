<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
	xmlns:camel="http://camel.apache.org/schema/blueprint"
	xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
	xmlns:cxf="http://camel.apache.org/schema/blueprint/cxf" xmlns:enc="http://karaf.apache.org/xmlns/jasypt/v1.0.0"
	xmlns:ext="http://aries.apache.org/blueprint/xmlns/blueprint-ext/v1.0.0"
	xmlns:http="http://cxf.apache.org/transports/http/configuration"
	xmlns:jaxws="http://cxf.apache.org/blueprint/jaxws" xmlns:sec="http://cxf.apache.org/configuration/security"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://cxf.apache.org/transports/camel http://cxf.apache.org/transports/camel.xsd        https://www.osgi.org/xmlns/blueprint/v1.0.0 http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd        http://camel.apache.org/schema/blueprint/cxf http://camel.apache.org/schema/blueprint/cxf/camel-cxf.xsd        http://camel.apache.org/schema/blueprint http://camel.apache.org/schema/blueprint/camel-blueprint.xsd">
	<cm:property-placeholder
		id="property-placeholder-43d8249f-f960-454c-8860-df868e252601"
		persistent-id="org.apache.cxf.osgi" placeholder-prefix="$("
		placeholder-suffix=")" update-strategy="reload">
		<cm:default-properties>
			<cm:property name="esbapi.global.properties.filepath"
				value="esbapi.global.properties.filepath" />
			<cm:property name="esbapi.apollo.properties.filepath"
				value="esbapi.apollo.properties.filepath" />
		</cm:default-properties>
	</cm:property-placeholder>
	<ext:property-placeholder
		id="property-placeholder-ca7d1865-139d-4d2f-90ed-bdf2526e45fa"
		placeholder-prefix="{{" placeholder-suffix="}}">
		<ext:location>file:$(esbapi.global.properties.filepath)</ext:location>
		<ext:location>file:$(esbapi.apollo.properties.filepath)</ext:location>
	</ext:property-placeholder>
	<enc:property-placeholder
		id="property-placeholder-3215c686-fcbe-4c37-a540-5afe82f199f1"
		placeholder-prefix="ENC(" placeholder-suffix=")">
		<enc:encryptor class="org.jasypt.encryption.pbe.StandardPBEStringEncryptor">
			<property name="config">
				<bean class="org.jasypt.encryption.pbe.config.EnvironmentStringPBEConfig">
					<property name="algorithm">
						<bean class="com.aviva.ca.vault.service.VaultService"
							factory-method="getKeyValue">
							<argument value="Algorithm" />
						</bean>
					</property>
					<property name="password">
						<bean class="com.aviva.ca.vault.service.VaultService"
							factory-method="getKeyValue">
							<argument value="MasterKey" />
						</bean>
					</property>
				</bean>
			</property>
		</enc:encryptor>
	</enc:property-placeholder>
	<http:conduit id="conduit-95ee9c8a-cad6-4870-ac6b-ecff0df41009"
		name=".*">
		<http:tlsClientParameters disableCNCheck="true">
			<sec:keyManagers keyPassword="{{KEYSTORE_PASSWORD}}">
				<sec:keyStore file="{{KEYSTORE_RESOURCE}}" password="{{KEYSTORE_PASSWORD}}"
					type="JKS" />
			</sec:keyManagers>
			<sec:trustManagers>
				<sec:keyStore file="{{TRUSTSTORE_RESOURCE}}" password="{{TRUSTSTORE_PASSWORD}}"
					type="JKS" />
			</sec:trustManagers>
		</http:tlsClientParameters>
		<http:client AutoRedirect="true" Connection="Keep-Alive" />
	</http:conduit>
	<camelContext id="_apolloApiContext"
		xmlns="http://camel.apache.org/schema/blueprint">
		<routeContextRef ref="logging_routeContext" />
		<route id="apolloInitialRoute" trace="false">
			<from uri="cxf:bean:apolloServiceEndpoint">
				<description />
			</from>
			<doTry>
				<log message="Operation Name  ${header.operationName} " id="_log1OperationName" />
				<setProperty propertyName="IS_ERROR">
					<simple resultType="java.lang.Boolean">false</simple>
				</setProperty>
				<setProperty propertyName="transactionLog">
					<simple>ref:transactionLog</simple>
				</setProperty>
				<setProperty propertyName="APPLICATION_ID">
					<simple>Apollo</simple>
				</setProperty>
				<bean method="setCommonLoggingProperties" ref="loggingProcessor" />
				<process ref="apolloInputProcessor" />
				<setHeader headerName="REQUEST_CORRELATION_ID">
					<simple resultType="java.lang.String">${header.Correlation-ID}</simple>
				</setHeader>
				<setProperty propertyName="REQUEST_CORRELATION_ID">
					<simple resultType="java.lang.String">${header.Correlation-ID}</simple>
				</setProperty>
				<setProperty propertyName="INBOUND_APPLICATION_ID">
					<simple resultType="java.lang.String">Apollo</simple>
				</setProperty>
				<to uri="direct:apolloCCJaxWSWebserviceCall" />
				<setProperty propertyName="APPLICATION_ID">
					<simple>Apollo</simple>
				</setProperty>
				<process ref="apolloResponseMapper" />
				<to uri="direct:logInboundSuccess" />
				<doCatch>
					<exception>java.lang.Exception</exception>
					<handled>
						<constant>true</constant>
					</handled>
					<process ref="errorHandler" />
					<to uri="direct:logInboundError" />
					<log loggingLevel="DEBUG" message="Successfully Logged Inbound Error" />
				</doCatch>
			</doTry>
			<!-- </when> <otherwise> <to uri="direct:sendRequestToInitialQueue" /> 
				</otherwise> </choice> -->
			<!-- <setBody> <simple>${exchangeProperty.INBOUND_RESPONSE}</simple> </setBody> -->

			<to uri="log:output" />
		</route>
		<route id="apolloCCJaxWSWebserviceCallRoute">
			<from uri="direct:apolloCCJaxWSWebserviceCall" />
			<doTry>
				<setProperty propertyName="APPLICATION_ID">
					<simple>CC</simple>
				</setProperty>
				<setProperty propertyName="URL">
					<simple>{{APOLLO_CC_ENDPOINT_URL}}</simple>
				</setProperty>
				<setProperty propertyName="OPERATION_NAME">
					<simple>receiveFile</simple>
				</setProperty>

				<to pattern="InOut" uri="bean:apolloCCServiceClient?method=receiveFile" />
				<to uri="direct:logOutboundSuccess" />
				<doCatch>
					<exception>java.lang.Exception</exception>
					<handled>
						<constant>true</constant>
					</handled>
					<process ref="errorHandler" />
					<to uri="direct:logOuboundError" />
					<log loggingLevel="DEBUG" message="Successfully Logged Outbound Error" />
				</doCatch>
			</doTry>
		</route>
		<route id="apolloInitialQueueProducerRoute">
			<from uri="direct:sendRequestToInitialQueue" />
			<log
				message="REQUEST_CORRELATION_ID : ${exchangeProperty.REQUEST_CORRELATION_ID} :: Apollo flow starts here"
				loggingLevel="INFO" />

			<process ref="initialQueuePreProcessor" />
			<inOnly
				uri="activemqesignature:{{CIP_APOLLO_INITIAL_QUEUE}}?headerFilterStrategy=#activeMQHeaderFilter" />
		</route>
		<route id="eSignatureInitialQueueConsumerRoute">
			<from uri="activemqesignature:{{CIP_APOLLO_INITIAL_QUEUE}}" />
			<process ref="initialQueuePostProcessor" />
			<log loggingLevel="INFO"
				message="${exchangeProperty.SERVICE} :: REQUEST_CORRELATION_ID : ${header.Correlation-ID} ; :  in eSignatureInitialQueueConsumerRoute, request consumed from {{CIP_APOLLO_INITIAL_QUEUE}}" />

		</route>

	</camelContext>

</blueprint>
